# Copie para .env e ajuste se necessário.
# Com o Postgres só na rede do Compose (sem `ports:` no serviço `db`), o app na mesma rede usa o hostname `db`.
# Para desenvolvimento no host com porta publicada (override) ou Postgres local, use `localhost` no lugar de `db`.
DATABASE_URL="postgresql://mixinvent:mixinvent_dev@db:5432/mixinvent"

# ManageEngine Endpoint Central (sincronização de inventário — /admin/sync)
MANAGEENGINE_API_KEY=seu_token_aqui
MANAGEENGINE_SERVER_URL=https://seu-servidor:8020
# Opcional: se sua instância usar API 1.4 em vez de v1:
# MANAGEENGINE_INVENTORY_COMPUTERS_PATH=/api/1.4/inventory/hardware
# Opcional: cabeçalho de auth (padrão Authorization)
# MANAGEENGINE_AUTH_HEADER_NAME=Authorization
#
# As mesmas opções podem ser gravadas no banco em /admin/integracoes (tabela system_settings).

# Microsoft Entra ID / Graph (sincronização de colaboradores — client credentials)
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# Ou configure na aba "Microsoft Entra ID" em /admin/integracoes.
